{% extends "layout.twig" %}

{% block content %}
{% include "partials/header.twig" %}

<!-- Carousel Banner -->
<div class="container mt-4 mb-2">
    <div class="owl-carousel owl-theme overflow-hidden" id="heroCarousel">
        <div class="item">
            <img src="/assets/img/slide1.jpg" alt="Informasi Dukcapil 1" class="w-100">
        </div>
        <div class="item">
            <img src="/assets/img/slide2.jpg" alt="Informasi Dukcapil 2" class="w-100">
        </div>
        <div class="item">
            <img src="/assets/img/slide3.jpg" alt="Informasi Dukcapil 3" class="w-100">
        </div>
        <div class="item">
            <img src="/assets/img/slide4.jpg" alt="Informasi Dukcapil 4" class="w-100">
        </div>
    </div>
</div>

<!-- Content -->
<div class="container py-5">
    <!-- Section Berita & Kegiatan -->
    <div class="mb-5">
        <div class="d-flex align-items-center mb-4">
            <h3 class="fw-bold mb-0 text-dark">Berita & Kegiatan</h3>
            <div class="ms-3 flex-grow-1 border-top border-2 border-primary opacity-25"></div>
        </div>
        <div class="owl-carousel owl-theme" id="newsOwlCarousel">
            {% for value in data %}
                <div class="item h-100 pb-2">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden" style="transition: transform 0.3s, box-shadow 0.3s;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 .5rem 1rem rgba(0,0,0,.15)'" onmouseout="this.style.transform='none'; this.style.boxShadow='0 .125rem .25rem rgba(0,0,0,.075)'">
                        <img src="https://files.dukcapil.tapinkab.go.id/{{ value.cover }}" class="card-img-top w-100" alt="..." style="object-fit: cover; aspect-ratio: 16/9; height: 220px;">
                        <div class="card-body d-flex flex-column p-4">
                            <p class="text-muted small mb-2"><i class="bi bi-calendar3 me-1"></i> {{ value.created|tgl_indo }}</p>
                            <h5 class="card-title fs-5 fw-semibold flex-grow-1 text-dark" style="line-height: 1.4;">{{ value.title }}</h5>
                        </div>
                        <div class="card-footer border-0 bg-transparent px-4 pb-4 mt-auto">
                            <a href="{{ value.permalink }}" class="text-primary text-decoration-none fw-medium" target="_blank">
                                Selengkapnya <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

    <!-- Section Layanan & FAQ -->
    <div class="row g-5">
        <!-- Menu Layanan -->
        <div class="col-lg-7">
            <div class="d-flex align-items-center mb-4">
                <h3 class="fw-bold mb-0 text-dark">Layanan Publik</h3>
                <div class="ms-3 flex-grow-1 border-top border-2 border-primary opacity-25"></div>
            </div>
            
            <div class="row g-4">
                <!-- Pondok Dukcapil -->
                <div class="col-sm-6">
                    <a href="https://pondok.dukcapil.tapinkab.go.id" target="_blank" class="text-decoration-none">
                        <div class="card h-100 border-0 shadow-sm rounded-4" style="transition: transform 0.3s; background: linear-gradient(145deg, #ffffff, #f8f9fa);" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='none'">
                            <div class="card-body p-4 text-center">
                                <div class="mb-3">
                                    <img src="/assets/img/ONLINE.png" alt="Pondok Dukcapil Icon" style="width: 56px; height: 56px; object-fit: contain; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));">
                                </div>
                                <h5 class="card-title fw-bold text-dark mb-2">Pondok Dukcapil</h5>
                                <p class="card-text text-muted small mb-0">Layanan adminduk online terpadu (KK, Akta, Pindah).</p>
                            </div>
                        </div>
                    </a>
                </div>
                
                <!-- IKD -->
                <div class="col-sm-6">
                    <a href="/publikasi/identitas-kependudukan-digital" target="_blank" class="text-decoration-none">
                        <div class="card h-100 border-0 shadow-sm rounded-4" style="transition: transform 0.3s; background: linear-gradient(145deg, #ffffff, #f8f9fa);" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='none'">
                            <div class="card-body p-4 text-center">
                                <div class="mb-3">
                                    <img src="/assets/img/IKD.png" alt="IKD Icon" style="width: 56px; height: 56px; object-fit: contain; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));">
                                </div>
                                <h5 class="card-title fw-bold text-dark mb-2">IKD</h5>
                                <p class="card-text text-muted small mb-0">Identitas Kependudukan Digital (KTP Digital).</p>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Petaku -->
                <div class="col-sm-6">
                    <a href="https://petaku.dukcapil.tapinkab.go.id/" target="_blank" class="text-decoration-none">
                        <div class="card h-100 border-0 shadow-sm rounded-4" style="transition: transform 0.3s; background: linear-gradient(145deg, #ffffff, #f8f9fa);" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='none'">
                            <div class="card-body p-4 text-center">
                                <div class="mb-3">
                                    <img src="/assets/img/petaku.png" alt="Petaku Icon" style="width: 56px; height: 56px; object-fit: contain; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));">
                                </div>
                                <h5 class="card-title fw-bold text-dark mb-2">Petaku</h5>
                                <p class="card-text text-muted small mb-0">Pusat Data Agregat Kependudukan Kab. Tapin.</p>
                            </div>
                        </div>
                    </a>
                </div>

                <!-- Lentera Pian -->
                <div class="col-sm-6">
                    <a href="https://lenterapian.dukcapil.tapinkab.go.id" target="_blank" class="text-decoration-none">
                        <div class="card h-100 border-0 shadow-sm rounded-4" style="transition: transform 0.3s; background: linear-gradient(145deg, #ffffff, #f8f9fa);" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='none'">
                            <div class="card-body p-4 text-center">
                                <div class="mb-3">
                                    <img src="/assets/img/lenterapian.png" alt="Lentera Pian Icon" style="width: 56px; height: 56px; object-fit: contain; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));">
                                </div>
                                <h5 class="card-title fw-bold text-dark mb-2">Lentera Pian</h5>
                                <p class="card-text text-muted small mb-0">Layanan Terintegrasi Pencatatan Kematian.</p>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <!-- FAQ -->
        <div class="col-lg-5">
            <div class="d-flex align-items-center mb-4">
                <h3 class="fw-bold mb-0 text-dark">Informasi Publik (FAQ)</h3>
                <div class="ms-3 flex-grow-1 border-top border-2 border-primary opacity-25"></div>
            </div>
            
            <div class="accordion accordion-flush bg-white rounded-4 shadow-sm p-2" id="faqAccordion">
                <!-- FAQ 1 -->
                <div class="accordion-item border-bottom border-light">
                    <h2 class="accordion-header" id="headingOne">
                        <button class="accordion-button collapsed bg-white text-dark fw-medium py-3 px-3 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="false" aria-controls="collapseOne">
                            <i class="bi bi-info-circle text-primary me-3 fs-5"></i>
                            Dimana saya bisa melihat info persyaratan dokumen?
                        </button>
                    </h2>
                    <div id="collapseOne" class="accordion-collapse collapse" aria-labelledby="headingOne" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted px-4 pt-0 pb-4">
                            Semua persyaratan dan tatacara penerbitan dokumen kependudukan dapat dilihat pada menu <strong>Layanan</strong> di bagian atas.
                        </div>
                    </div>
                </div>

                <!-- FAQ 2 -->
                <div class="accordion-item border-bottom border-light">
                    <h2 class="accordion-header" id="headingTwo">
                        <button class="accordion-button collapsed bg-white text-dark fw-medium py-3 px-3 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                            <i class="bi bi-chat-text text-primary me-3 fs-5"></i>
                            Bagaimana cara mengajukan permohonan?
                        </button>
                    </h2>
                    <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted px-4 pt-0 pb-4">
                            Dapat dilakukan dengan cara:
                            <ol class="mt-2 mb-0 ps-3">
                                <li>Datang langsung ke Kantor Disdukcapil Kab. Tapin pada jam kerja.</li>
                                <li>Menghubungi nomor Layanan WhatsApp yang tersedia.</li>
                                <li>Melalui petugas desa terdekat.</li>
                            </ol>
                        </div>
                    </div>
                </div>

                <!-- FAQ 3 -->
                <div class="accordion-item border-bottom border-light">
                    <h2 class="accordion-header" id="headingThree">
                        <button class="accordion-button collapsed bg-white text-dark fw-medium py-3 px-3 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                            <i class="bi bi-box-seam text-primary me-3 fs-5"></i>
                            Dimana tempat pengambilan dokumen online?
                        </button>
                    </h2>
                    <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingThree" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted px-4 pt-0 pb-4">
                            <ol class="mb-0 ps-3">
                                <li>Di Kantor Disdukcapil setelah menerima notifikasi dari petugas.</li>
                                <li>Melalui jasa pengantaran PT. POS langsung ke alamat pemohon.</li>
                            </ol>
                        </div>
                    </div>
                </div>

                <!-- FAQ 4 -->
                <div class="accordion-item border-bottom border-light">
                    <h2 class="accordion-header" id="headingFour">
                        <button class="accordion-button collapsed bg-white text-dark fw-medium py-3 px-3 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFour" aria-expanded="false" aria-controls="collapseFour">
                            <i class="bi bi-exclamation-triangle text-primary me-3 fs-5"></i>
                            Bagaimana cara menyampaikan pengaduan?
                        </button>
                    </h2>
                    <div id="collapseFour" class="accordion-collapse collapse" aria-labelledby="headingFour" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted px-4 pt-0 pb-4">
                            Pengaduan dapat disampaikan melalui:
                            <ul class="mt-2 mb-0 ps-3">
                                <li>Kotak Pengaduan di Kantor Disdukcapil.</li>
                                <li>WhatsApp: <strong>0811-511-3141</strong></li>
                                <li>Email: <strong>pengaduan@dukcapil.tapinkab.go.id</strong></li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- FAQ 5 -->
                <div class="accordion-item border-bottom border-light">
                    <h2 class="accordion-header" id="headingFive">
                        <button class="accordion-button collapsed bg-white text-dark fw-medium py-3 px-3 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFive" aria-expanded="false" aria-controls="collapseFive">
                            <i class="bi bi-cash-stack text-primary me-3 fs-5"></i>
                            Apakah ada biaya pengurusan dokumen?
                        </button>
                    </h2>
                    <div id="collapseFive" class="accordion-collapse collapse" aria-labelledby="headingFive" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted px-4 pt-0 pb-4">
                            Tidak, semua layanan dokumen kependudukan <strong class="text-danger">GRATIS!</strong> Tidak dipungut biaya apapun.
                        </div>
                    </div>
                </div>

                <!-- FAQ 6 -->
                <div class="accordion-item border-0">
                    <h2 class="accordion-header" id="headingSix">
                        <button class="accordion-button collapsed bg-white text-dark fw-medium py-3 px-3 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSix" aria-expanded="false" aria-controls="collapseSix">
                            <i class="bi bi-file-earmark-check text-primary me-3 fs-5"></i>
                            Bagaimana cara melegalisir dokumen?
                        </button>
                    </h2>
                    <div id="collapseSix" class="accordion-collapse collapse" aria-labelledby="headingSix" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted px-4 pt-0 pb-4">
                            Dokumen kependudukan yang sudah memiliki barcode atau Tanda Tangan Elektronik (TTE) <strong>tidak perlu dilegalisir</strong>.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% include "partials/footer.twig" %}
{% endblock %}
